APP_NAME=ISS Telemetry API
APP_ENV=dev
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

LIGHTSTREAMER_SERVER=https://push.lightstreamer.com
LIGHTSTREAMER_ADAPTER_SET=ISSLIVE

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TELEMETRY_TOPIC=telemetry.raw
KAFKA_ANOMALY_TOPIC=anomaly.events
KAFKA_CONSUMER_GROUP=iss-worker
KAFKA_NOTIFICATION_CONSUMER_GROUP=iss-notifications

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=iss_telemetry
POSTGRES_USER=iss_user
POSTGRES_PASSWORD=iss_password

CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REDIS_RECENT_HISTORY_LIMIT=100
TELEMETRY_RETENTION_DAYS=28
DEFAULT_NOTIFICATION_COOLDOWN_MINUTES=10
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=iss-alerts@example.com
APP_BASE_URL=http://localhost:8000

# Optional override:
# DATABASE_URL=postgresql+psycopg://iss_user:iss_password@localhost:5432/iss
