APP_ENV=production
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

LIGHTSTREAMER_SERVER=https://push.lightstreamer.com
LIGHTSTREAMER_ADAPTER_SET=ISSLIVE

# Local host usage: localhost:9092
# Docker Compose backend usage: kafka:19092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TELEMETRY_TOPIC=telemetry.raw
KAFKA_ANOMALY_TOPIC=anomaly.events
KAFKA_INJECTION_TOPIC=injection.jobs
KAFKA_CONSUMER_GROUP=iss-worker
KAFKA_NOTIFICATION_CONSUMER_GROUP=iss-notifications
KAFKA_INJECTION_CONSUMER_GROUP=iss-injection-worker

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=iss_telemetry
POSTGRES_USER=iss_user
POSTGRES_PASSWORD=iss_password

# Set this to your deployed frontend URL once Vercel is connected.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app

RULES_FILE_PATH=config/rules.json
DATA_ROOT=data
COLLECTOR_RAW_ROOT=data/raw
COLLECTOR_MANIFEST_PATH=data/manifest.json
REDIS_TELEMETRY_LIVE_CHANNEL=telemetry:live
PROTOTYPE_LIBRARY_DIR=data/anomaly_prototypes/smap_final9_v01
COLLECTOR_DIAGNOSTICS_PATH=data/diagnostics/collector_gaps.jsonl
COLLECTOR_HEARTBEAT_WARN_SECONDS=15
COLLECTOR_HEARTBEAT_RECONNECT_SECONDS=45
COLLECTOR_GAP_THRESHOLD_SECONDS=60
APP_INGEST_DIAGNOSTICS_PATH=data/diagnostics/ingest_gaps.jsonl
APP_INGEST_HEARTBEAT_WARN_SECONDS=15
APP_INGEST_HEARTBEAT_RECONNECT_SECONDS=45
APP_INGEST_GAP_THRESHOLD_SECONDS=60
REDIS_RECENT_HISTORY_LIMIT=100
REDIS_FEATURE_WINDOW_SIZE=100
INJECTION_MAX_POINTS=500
TELEMETRY_RETENTION_DAYS=28
WORKER_REDIS_RETRY_MAX_SECONDS=60
WORKER_REDIS_HEALTH_DEGRADED_AFTER_SECONDS=300
ANOMALY_POST_INJECTION_COOLDOWN_SECONDS=10
STARTUP_DEPENDENCY_RETRY_ATTEMPTS=10
STARTUP_DEPENDENCY_RETRY_DELAY_SECONDS=3
DEFAULT_NOTIFICATION_COOLDOWN_MINUTES=10

EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=iss-alerts@example.com
APP_BASE_URL=http://localhost:8000
